# Copy this file to `.env` and fill in your own values (`.env` is gitignored).

# MongoDB Atlas connection string. Get it from Atlas > Connect > Drivers.
# Replace <user> and <db_password> with your database user's credentials.
DB_CONN_STRING=mongodb+srv://<user>:<db_password>...

# Database and collection the backend reads/writes.
DB_NAME=db_name_here
COLLECTION_NAME=collection_name_here

# Port the backend API listens on (the frontend expects 3001).
PORT=3001

# Clerk (auth). From the Clerk dashboard > API keys. Must be the SAME Clerk
# instance the frontend uses, so the backend can verify the tokens it issues.
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
