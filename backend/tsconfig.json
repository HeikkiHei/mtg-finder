{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    /* Runs on Node 24 via ts-node, so target a modern runtime. ES2022 keeps
       async/await native instead of downleveling. `nodenext` is the current,
       non-deprecated resolver; with no "type" in package.json these .ts files
       still emit as CommonJS. */
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",

    /* Build output (ts-node ignores this; used by a future `tsc` build). */
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "jest.config.js"]
}
