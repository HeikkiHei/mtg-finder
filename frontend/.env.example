# Copy this file to `.env.local` and fill in your own values (gitignored).

# Clerk (auth). From the Clerk dashboard > API keys. Use the SAME Clerk
# instance as the backend so it can verify the session tokens.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Where the Next dev server proxies /api/* (defaults to http://localhost:3001).
# BACKEND_URL=http://localhost:3001
