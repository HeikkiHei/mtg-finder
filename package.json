{
  "name": "mtg-finder",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start:frontend": "npm --prefix frontend start",
    "start:backend": "npm --prefix backend start",
    "start": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "npm --prefix backend run dev",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=high",
    "typecheck": "tsc -p backend/tsconfig.json --noEmit && tsc -p frontend/tsconfig.json --noEmit && tsc -p tsconfig.config.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.61.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "mongodb": "^7.2.0",
    "typescript": "^6.0.3"
  },
  "comments": {
    "overrides": {
      "@types/multer": "Depends on @types/express@* which would resolve to the v4 types; pin to v5 so it matches the express-5 backend and doesn't reintroduce the removed `req.param` Request type.",
      "postcss": "Next 16 still bundles postcss 8.4.31 (moderate XSS advisory GHSA-qx2v-qp2m-jg93). Pin to the patched 8.5.x — a same-major bump Next tolerates — instead of npm's absurd 'fix' of downgrading Next to 9.x. No --force/--legacy-peer-deps needed."
    }
  },
  "overrides": {
    "@types/multer": {
      "@types/express": "^5.0.6"
    },
    "postcss": "^8.5.15"
  }
}
