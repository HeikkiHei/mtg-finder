{
  // Type-checks the repo-root config files (Jest + ESLint), which live outside
  // the backend/ and frontend/ projects. Wired into `npm run typecheck`.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"]
  },
  "include": ["jest.config.ts", "eslint.config.ts"]
}
