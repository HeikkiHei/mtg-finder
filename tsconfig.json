{
  // Shared base for the workspace. Sub-projects (backend/, frontend/) extend
  // this and add their own target/module/lib + `include`. The empty `files`
  // list means running `tsc` at the repo root compiles nothing on its own,
  // rather than trying to build both workspaces under one set of options.
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "files": []
}
